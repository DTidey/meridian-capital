# Copy to .env and fill in your keys

# PostgreSQL connection — overrides config.yaml database.url
# DATABASE_URL=postgresql+psycopg2://meridian:meridian@localhost:5432/meridian
POSTGRES_PASSWORD=meridian

# All market-data keys are optional — the system falls back to free data sources

# Polygon.io — licensed exchange data for daily prices
POLYGON_API_KEY=

# Financial Modeling Prep — earnings transcripts + structured financials
FMP_API_KEY=

# FRED (Federal Reserve) — macro data: yield curve, credit spreads, fed funds
FRED_API_KEY=

# OpenFIGI — CUSIP → ticker resolution for institutional holdings
# Free registration at https://www.openfigi.com/user/login
# Without this, holdings are matched by company name against the S&P 500 universe only
OPENFIGI_API_KEY=

# SEC EDGAR contact (required by SEC fair-use policy)
SEC_USER_EMAIL=your@email.com
SEC_USER_AGENT=MeridianCapital/1.0
